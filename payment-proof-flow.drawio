<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <mxCell id="hp" value="PLAYER — Upload Payment Proof" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;" vertex="1" parent="1">
      <mxGeometry x="250" y="0" width="220" height="34" as="geometry"/>
    </mxCell>

    <mxCell id="n1" value="Booking confirmed&#xa;Payment PENDING (offline, unpaid)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
      <mxGeometry x="250" y="60" width="220" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="n2" value="Player taps&#xa;&lt;b&gt;Upload Payment Proof&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="250" y="160" width="220" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="d1" value="Replacing an&#xa;existing proof?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="260" y="260" width="200" height="90" as="geometry"/>
    </mxCell>

    <mxCell id="n3" value="Confirm overwrite&#xa;(cannot be undone)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="560" y="275" width="200" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="n4" value="Pick image from gallery&#xa;(compress 70%, max 10 MB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="250" y="390" width="220" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="n5" value="1. Get presigned S3 URL&#xa;POST /receipt/upload-url" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="250" y="490" width="220" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="n6" value="2. Upload image to S3&#xa;(direct PUT to presigned URL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="250" y="590" width="220" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="n7" value="3. Confirm receipt with backend&#xa;PUT /bookings/{id}/receipt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="250" y="690" width="220" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="n8" value="Booking updated:&#xa;hasReceipt=true&#xa;paymentStatus still UNPAID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="250" y="790" width="220" height="70" as="geometry"/>
    </mxCell>

    <mxCell id="n9" value="Notify organiser&#xa;(payment_proof_uploaded)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="250" y="900" width="220" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="n10" value="Player sees:&#xa;&quot;Pending organiser approval&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="250" y="1000" width="220" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="ho" value="ORGANISER — Approve Payment Proof" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=13;" vertex="1" parent="1">
      <mxGeometry x="250" y="1100" width="220" height="34" as="geometry"/>
    </mxCell>

    <mxCell id="n11" value="Organiser sees&#xa;&quot;Pending Approval&quot; badge&#xa;(pendingApprovalCount &gt; 0)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
      <mxGeometry x="250" y="1160" width="220" height="70" as="geometry"/>
    </mxCell>

    <mxCell id="n12" value="Open Game Manage&#xa;&#8594; bookings list" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
      <mxGeometry x="250" y="1270" width="220" height="60" as="geometry"/>
