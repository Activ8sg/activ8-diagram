    <mxCell id="n13" value="Tap receipt icon &#8594;&#xa;view proof (ReceiptViewerSheet,&#xa;presigned image URL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
      <mxGeometry x="250" y="1370" width="220" height="70" as="geometry"/>
