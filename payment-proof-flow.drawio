    <mxCell id="d2" value="Payment received&#xa;&amp; valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="260" y="1480" width="200" height="90" as="geometry"/>
    </mxCell>

    <mxCell id="n14" value="No explicit reject:&#xa;do nothing&#xa;(player can re-upload)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="560" y="1490" width="200" height="70" as="geometry"/>
    </mxCell>

    <mxCell id="n15" value="Tap &lt;b&gt;Mark Paid&lt;/b&gt;&#xa;&#8594; confirm dialog&#xa;(&quot;cannot be undone&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
      <mxGeometry x="250" y="1600" width="220" height="70" as="geometry"/>
    </mxCell>

    <mxCell id="n16" value="PATCH .../payment-status&#xa;{ paid: true }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
      <mxGeometry x="250" y="1710" width="220" height="60" as="geometry"/>
    </mxCell>

    <mxCell id="n17" value="paymentStatus = PAID&#xa;pendingApprovalCount--&#xa;earnings/payout triggered" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
