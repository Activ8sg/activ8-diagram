        </mxCell>
        <mxCell id="rf-cron" value="CRON — every 15 min (app.js)&#10;runs BEFORE earnings settlement" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088" vertex="1" parent="rf1">
          <mxGeometry x="700" y="540" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rf-cronFn" value="fn_auto_approve_expired_refunds&#10;(grace_hours — admin_config, default 24)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b0e3e6;strokeColor=#0e8088" vertex="1" parent="rf1">
