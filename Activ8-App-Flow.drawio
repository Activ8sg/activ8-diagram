        </mxCell>
        <mxCell id="rf-dCron" value="Pending request AND&#10;game ended &amp;gt; grace?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="rf1">
          <mxGeometry x="710" y="720" width="230" height="100" as="geometry" />
