        </mxCell>
        <mxCell id="rf-invariant" value="INVARIANT&#10;A PENDING request's earning is never cashable.&#10;Earnings settlement matures only status=&#39;confirmed&#39;&#10;bookings; the auto-approve sweep runs BEFORE&#10;settlement, so these earnings are reversed, not matured." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;verticalAlign=top;size=18" vertex="1" parent="rf1">
