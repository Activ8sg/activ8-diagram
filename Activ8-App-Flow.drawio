        <mxCell id="rf-notifyOrg" value="Notify organizer&#10;&#34;Refund requested&#34; + reason" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="rf1">
          <mxGeometry x="300" y="660" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rf-managePage" value="Manage page (organizer)&#10;Amber &#34;REFUND REQUESTED&#34; footer&#10;shows reason + DECIDE button" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00" vertex="1" parent="rf1">
          <mxGeometry x="300" y="740" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="rf-dialog" value="RefundDecisionDialog&#10;No refund  /  Full  /  Custom amount&#10;POST /games/:id/bookings/:id/refund-decision&#10;{ refundAmount, note? }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00" vertex="1" parent="rf1">
          <mxGeometry x="290" y="840" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="rf-rpc" value="fn_resolve_refund_request  (atomic, SECURITY DEFINER)&#10;&#10;• Refund player wallet  + R  (spendable balance)&#10;• Reverse original earning out of pending_earnings&#10;• Organizer KEEPS (total − R) as matured cashable earning&#10;• Stamp booking: approved / denied&#10;  → refunded / partial_refund / no_refund" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="rf1">
          <mxGeometry x="230" y="970" width="400" height="160" as="geometry" />
        </mxCell>
        <mxCell id="rf-notifyPlayer" value="Notify player&#10;wallet_refund (approved)  /  refund_declined (denied)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="rf1">
          <mxGeometry x="280" y="1170" width="300" height="50" as="geometry" />
